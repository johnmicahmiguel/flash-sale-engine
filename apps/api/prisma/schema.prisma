generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  name  String

  @@map("users")
}

model Sale {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  slug               String     @unique
  name               String
  tagline            String
  productImageEmoji  String
  priceCents         Int
  originalPriceCents Int
  currency           String
  editionNumber      Int
  editionTotal       Int
  totalStock         Int
  remainingStock     Int
  startsAt           DateTime
  endsAt             DateTime
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  purchases          Purchase[]

  @@map("sales")
}

model Purchase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  saleId      String   @db.ObjectId
  userId      String
  purchasedAt DateTime @default(now())
  sale        Sale     @relation(fields: [saleId], references: [id])

  @@unique([saleId, userId])
  @@map("purchases")
}
